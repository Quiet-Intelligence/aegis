# Aegis daemon configuration.
# Copy this file to aegis.env and edit. aegis.env is gitignored.
# aegisctl provider set writes provider/model selections here, but
# NEVER writes API keys. Keys go in this file by hand, or in the
# process environment.

# Provider preset from providers.json
# (openai, openrouter, groq, together, ollama, custom)
AEGIS_PROVIDER=openai

# API key for the provider. Keep it secret.
# The daemon checks the preset's key_env (OPENAI_API_KEY for openai),
# then AEGIS_LLM_KEY, then OPENAI_API_KEY.
# OPENROUTER_API_KEY=sk-or-v1-...   # when AEGIS_PROVIDER=openrouter
# AEGIS_LLM_KEY=sk-...              # generic fallback for any provider

# Model overrides (optional). AEGIS_LLM_MODEL sets both tiers at once;
# the tier-specific vars override their own tier only.
# Defaults for openai: cheap=gpt-4o, flagship=gpt-5.6-sol
# AEGIS_LLM_MODEL=
# AEGIS_CHEAP_MODEL=gpt-4o
# AEGIS_FLAGSHIP_MODEL=gpt-5.6-sol

# Explicit endpoint override (optional; normally comes from the preset)
# AEGIS_LLM_URL=

# Discovery helpers:
#   aegisctl provider list       -> show presets
#   aegisctl provider current    -> show resolved config (key masked)
#   aegisctl provider models     -> list real model slugs from the provider
